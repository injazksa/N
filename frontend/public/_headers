# ═══════════════════════════════════════════════════════════════
# Netlify Headers — مكتب تأشيرات السعودية | v3.0 | 2026-05-07
# أمان متقدم + أداء + حماية من XSS والاختراق
# ═══════════════════════════════════════════════════════════════

/*
  # ── أمان ──
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://cdnjs.cloudflare.com https://fonts.googleapis.com https://identity.netlify.com https://unpkg.com https://cdn.jsdelivr.net https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://unpkg.com; img-src 'self' data: blob: https: https://static.prod-images.emergentagent.com https://www.facebook.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; connect-src 'self' https://*.tile.openstreetmap.org https://saudia-visa.com https://www.facebook.com https://connect.facebook.net https://identity.netlify.com https://api.github.com https://www.googletagmanager.com https://www.google-analytics.com; frame-src https://www.google.com https://www.facebook.com https://www.openstreetmap.org; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://identity.netlify.com; object-src 'none'; upgrade-insecure-requests
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-site
  # ── كاش افتراضي ──
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: text/html; charset=utf-8

/*.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  Content-Type: application/javascript; charset=utf-8

/*.css
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  Content-Type: text/css; charset=utf-8

/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate

/advanced-service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate

/images/*
  Cache-Control: public, max-age=31536000, immutable

/images-original/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

/favicon-32x32.png
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/manifest.json
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=86400

/llms-full.txt
  Cache-Control: public, max-age=86400

# ── بيانات المحتوى — مخفية عن الفهرسة ──
/content/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

# ── AI plugin JSON — للفهرسة الذكية ──
/.well-known/*
  Cache-Control: public, max-age=3600
  Content-Type: application/json; charset=utf-8

# ── security.txt الرسمي (معيار RFC 9116 للإبلاغ الأمني) ──
/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

# ═══════════════════════════════════════════════════════════════
# 🔒 BULLETPROOF SECURITY PATCH — حماية الملفات الحساسة (2026)
# منع الفهرسة + منع الكاش + منع التضمين لكل المسارات الإدارية والتكوينية
# ═══════════════════════════════════════════════════════════════

# ── لوحة الإدارة (Decap CMS) — محظورة تماماً عن البوتات ──
/admin-secure/*
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet, noimageindex
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer

# ── ملفات التكوين الحساسة — منع الوصول والفهرسة ──
/*.yml
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  X-Content-Type-Options: nosniff

/*.yaml
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/*.toml
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/*.env
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/*.config.js
  X-Robots-Tag: noindex, nofollow, noarchive

# ── ملفات النظام والمستودع — منع الفهرسة ──
/.git/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: no-store

/backend/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: no-store

/frontend/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: no-store

/.emergent/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: no-store
